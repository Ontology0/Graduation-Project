## Copy this file to `.env` and fill in secrets.
## Never commit `.env` (it is gitignored).

# HuggingFace
HF_TOKEN=

# OpenAI
OPENAI_API_KEY=

# Google
GOOGLE_API_KEY=

# Anthropic (Claude) API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram bot token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional hardening (comma-separated Telegram user IDs)
TELEGRAM_ALLOWED_USER_IDS=

# Rate limiting (per user, per minute)
TELEGRAM_RATE_LIMIT_PER_MIN=12

# Optional: send full run markdown on every answer (debug only; can be noisy)
TELEGRAM_SEND_RUN_MD=0
